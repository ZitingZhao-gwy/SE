PORT=8090
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=trading_client

# Central trading Kafka pipeline. Keep disabled until the central trading team
# provides the real broker address, topic names, and message format.
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=trading-client
KAFKA_GROUP_ID=trading-client-group
KAFKA_SSL=false
KAFKA_SSL_REJECT_UNAUTHORIZED=true
KAFKA_SSL_CA_PATH=
KAFKA_SSL_CERT_PATH=
KAFKA_SSL_KEY_PATH=
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SPRING_TYPE_HEADERS=true
KAFKA_STOCK_QUERY_TIMEOUT_MS=8000
KAFKA_TOPIC_ORDER_COMMAND=central.order.command
KAFKA_TOPIC_CANCEL_COMMAND=central.cancel.command
KAFKA_TOPIC_STOCK_QUERY=central.stock.query
KAFKA_TOPIC_STOCK_QUOTE=client.stock.quote
KAFKA_TOPIC_TRADE_REPORT=client.trade.report
KAFKA_TOPIC_ORDER_REPORT=client.order.report

# Local mock central trading Kafka service. It is only for integration rehearsal.
MOCK_CENTRAL_GROUP_ID=mock-central-trading-system
MOCK_CENTRAL_AUTO_TRADE=true
MOCK_CENTRAL_ACCEPT_DELAY_MS=200
MOCK_CENTRAL_TRADE_DELAY_MS=800
MOCK_CENTRAL_QUOTE_PRICE=1688.35
MOCK_CENTRAL_STOCK_NAME=Mock Stock
